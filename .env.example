# =============================================================================
# iGNYX Lease — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env.local e preencha os valores reais.
# Nunca commite .env.local — ele está no .gitignore.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="iGNYX Lease"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_TIMEZONE="America/Sao_Paulo"
NEXT_PUBLIC_DEFAULT_LOCALE="pt-BR"
NEXT_PUBLIC_DEFAULT_CURRENCY="BRL"

# -----------------------------------------------------------------------------
# Database (Postgres direto, via Drizzle)
# -----------------------------------------------------------------------------
# Use a connection string da pool transacional do Supabase (porta 6543)
# para serverless/edge, ou a direta (porta 5432) para migrations locais.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ignyx_lease"
DATABASE_DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ignyx_lease"

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
SUPABASE_JWT_SECRET="your-jwt-secret"

# -----------------------------------------------------------------------------
# Anthropic (Claude API)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-opus-4-7"

# -----------------------------------------------------------------------------
# Resend (Transactional Email)
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="iGNYX Lease <noreply@ignyxlease.com.br>"
RESEND_REPLY_TO="suporte@maff.com.br"

# -----------------------------------------------------------------------------
# Seed / Bootstrap
# -----------------------------------------------------------------------------
SEED_SUPERADMIN_EMAIL="yuri@maff.com.br"
SEED_SUPERADMIN_PASSWORD="change-me-on-first-login"
SEED_SUPERADMIN_NAME="Yuri Feres"
